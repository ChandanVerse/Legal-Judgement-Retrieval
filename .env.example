# Legal Case Similarity RAG System - Environment Configuration

# ===========================================
# GOOGLE GEMINI API (for chat)
# Get free key: https://aistudio.google.com/apikey
# ===========================================
GOOGLE_API_KEY=your_google_api_key_here

# ===========================================
# PINECONE VECTOR DATABASE
# ===========================================
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=legal-rag
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ===========================================
# MONGODB ATLAS (Full Case Text Storage)
# Format: mongodb+srv://username:password@cluster.mongodb.net/
# ===========================================
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGO_DB_NAME=legal_cases

# ===========================================
# NEO4J GRAPH DATABASE (Optional)
# ===========================================
NEO4J_URI=neo4j+s://your_neo4j_uri
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j

# ===========================================
# EMBEDDING MODEL
# ===========================================
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
EMBEDDING_DEVICE=cuda
# Use 'cpu' if no GPU available

# ===========================================
# TEXT PROCESSING
# ===========================================
CHUNK_SIZE=500
CHUNK_OVERLAP=100
MIN_PARAGRAPH_LENGTH=50

# ===========================================
# BATCH PROCESSING
# ===========================================
BATCH_SIZE=32
EMBEDDING_BATCH_SIZE=32
VECTOR_UPSERT_BATCH_SIZE=100

# ===========================================
# SEARCH CONFIGURATION
# ===========================================
TOP_K_RESULTS=10
GRAPH_CANDIDATE_LIMIT=50
SIMILARITY_THRESHOLD=0.5

# ===========================================
# RERANKING WEIGHTS (must sum to 1.0)
# ===========================================
WEIGHT_SIMILARITY=0.50
WEIGHT_PAGERANK=0.20
WEIGHT_RECENCY=0.10
WEIGHT_COURT=0.20

# Default score for courts not in hierarchy
COURT_DEFAULT_SCORE=0.5

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=INFO

# ===========================================
# AWS (Production Deployment)
# ===========================================
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
DYNAMODB_TABLE=legal-cases
S3_BUCKET=your_s3_bucket_name
