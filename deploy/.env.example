# Legal Case Similarity RAG System - EC2 Deployment Configuration

# ===========================================
# GOOGLE GEMINI API (for chat)
# ===========================================
GOOGLE_API_KEY=your_google_api_key

# ===========================================
# ENDEE VECTOR DATABASE
# ===========================================
ENDEE_URL=http://localhost:8080/api/v1
ENDEE_AUTH_TOKEN=your_endee_auth_token

# ===========================================
# MONGODB ATLAS
# ===========================================
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGO_DB_NAME=legal_cases

# ===========================================
# AWS Credentials (for DynamoDB + S3)
# ===========================================
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
DYNAMODB_TABLE=legal-cases
S3_BUCKET=your_s3_bucket_name

# ===========================================
# EMBEDDING MODEL (CPU on EC2)
# ===========================================
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
EMBEDDING_DEVICE=cpu

# ===========================================
# SERVER CONFIG
# ===========================================
API_PORT=8000
LOG_LEVEL=INFO
